# Browser-facing Supabase configuration.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_STORAGE_BUCKET=meal-photos

# Server-only Supabase configuration for Vercel functions and local scripts.
# Never expose SUPABASE_SERVICE_ROLE_KEY in browser code.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=meal-photos

# Direct ingest endpoint used by scripts and iPhone Shortcuts.
DIARY_INGEST_TOKEN=
DIARY_USER_EMAIL=
DIARY_USER_ID=

# Gemini image analysis. Keep this server-side only.
GEMINI_API_KEY=
GEMINI_MODEL=
GEMINI_MODELS=

# Optional local import override.
LOCAL_DIARY_DATA=
DIARY_PHOTO_PATH=
