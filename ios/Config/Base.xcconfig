// Shared build settings for DietCloud (public client config only).
// Do NOT put SERVICE_ROLE, GEMINI_API_KEY, or DIARY_INGEST_TOKEN here.
//
// IMPORTANT: In xcconfig, // starts a comment. Never write https:// literally.
// Use $(SLASH)$(SLASH) so URLs survive preprocessing.

SLASH = /

// Public Supabase project URL (safe to ship; protected by RLS).
SUPABASE_URL = https:$(SLASH)$(SLASH)YOUR_PROJECT.supabase.co

// Supabase anonymous / publishable key (safe to ship; protected by RLS).
SUPABASE_ANON_KEY = YOUR_SUPABASE_ANON_KEY

// Absolute Vercel (or local preview) origin for /api/analyze-* only.
API_BASE_URL = https:$(SLASH)$(SLASH)diet-cloud.vercel.app

// Private meal-photos bucket name (default matches Web).
STORAGE_BUCKET = meal-photos

// Magic Link redirect back into the iOS app (not a secret).
// Must also be listed in Supabase Dashboard → Auth → Redirect URLs.
DIETCLOUD_AUTH_REDIRECT_URL = dietcloud:$(SLASH)$(SLASH)auth-callback
