// Copy to Secrets.xcconfig (gitignored) and fill real PUBLIC client values.
// NEVER put SERVICE_ROLE / GEMINI_API_KEY / DIARY_INGEST_TOKEN here.
//
// IMPORTANT: Do NOT write https:// or dietcloud:// with raw slashes — // is a comment.
// Always use: https:$(SLASH)$(SLASH)host  and  dietcloud:$(SLASH)$(SLASH)auth-callback
// (SLASH is defined in Base.xcconfig.)

SLASH = /

SUPABASE_URL = https:$(SLASH)$(SLASH)YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY = YOUR_SUPABASE_ANON_KEY
API_BASE_URL = https:$(SLASH)$(SLASH)diet-cloud.vercel.app
STORAGE_BUCKET = meal-photos
DIETCLOUD_AUTH_REDIRECT_URL = dietcloud:$(SLASH)$(SLASH)auth-callback
