// Copy to Secrets.xcconfig (gitignored) and fill real public client values.
// NEVER put SERVICE_ROLE / GEMINI_API_KEY / DIARY_INGEST_TOKEN here.

SUPABASE_URL = https:/$()/YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY = YOUR_SUPABASE_ANON_KEY
API_BASE_URL = https:/$()/diet-cloud.vercel.app
STORAGE_BUCKET = meal-photos
// Public app callback only — also add this exact URL in Supabase Redirect URLs.
DIETCLOUD_AUTH_REDIRECT_URL = dietcloud:/$()/auth-callback
